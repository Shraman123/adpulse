# --- Required to run the AI Insights feature -------------------------------
# This build calls Groq's free, OpenAI-compatible API (see the "AI provider
# note" in README.md for why, and how to swap providers).
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Optional: override the default model (llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile

# --- Alternative provider (see README "AI provider note" for the swap) -----
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# ANTHROPIC_MODEL=your_chosen_claude_model
